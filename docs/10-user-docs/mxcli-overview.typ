/** Define a REST service consumed by your app */
CREATE REST CLIENT PaymentGateway.StripeAPI
BASE URL 'https://api.stripe.com/v1'
AUTHENTICATION BASIC
    USERNAME ''
    PASSWORD '[%StripeSecretKey%]'
TIMEOUT 30000
BEGIN
    OPERATION CreateCharge
        METHOD POST
        PATH '/charges'
        BODY '{
            "amount": ${amount},
            "currency": "${currency}",
            "source": "${token}",
            "description": "${description}"
        }'
        PARAMETER amount: Integer IN BODY
        PARAMETER currency: String IN BODY
        PARAMETER token: String IN BODY
        PARAMETER description: String IN BODY
        RESPONSE 200 PaymentGateway.ChargeResponse;

    OPERATION GetCharge
        METHOD GET
        PATH '/charges/${chargeId}'
        PARAMETER chargeId: String IN PATH
        RESPONSE 200 PaymentGateway.ChargeResponse;
END;
