== Defining Best Practices and Guardrails
<defining-best-practices-and-guardrails>
Organizations can define MDL templates that encode their standards:

=== Entity Naming Convention Template
<entity-naming-convention-template>
```sql
/**
 * Template: Standard Audit Fields.
 * All persistent entities should include these fields.
 * ${EntityDescription}
 */
@Position(${X}, ${Y})
CREATE PERSISTENT ENTITY ${Module}.${EntityName} (
    /** Business fields go here */
    ${BusinessFields}

    /** === STANDARD AUDIT FIELDS (Required) === */

    /** Record creation timestamp */
    CreatedAt: DateTime DEFAULT '[%CurrentDateTime%]',

    /** User who created this record */
    CreatedBy: String(200),

    /** Last modification timestamp */
    ModifiedAt: DateTime,

    /** User who last modified this record */
    ModifiedBy: String(200),

    /** Soft delete flag - never hard delete records */
    IsDeleted: Boolean DEFAULT false
);

/** Audit index for query performance */
CREATE INDEX idx_${EntityName}_audit
    ON ${Module}.${EntityName} (CreatedAt, ModifiedAt);
```

=== Microflow Error Handling Template
<microflow-error-handling-template>
```sql
/**
 * Template: Microflow with Standard Error Handling
 * Use ON ERROR blocks on specific activities that may fail.
 */
CREATE MICROFLOW ${Module}.${MicroflowName}(
    ${Parameters}
) RETURNS ${ReturnType} AS $result
BEGIN
    /** Initialize result */
    DECLARE $result ${ReturnType};

    /** Activity with error handling */
    CALL MICROFLOW ${Module}.RiskyOperation()
    ON ERROR {
        /** Log error with context */
        LOG ERROR NODE 'ErrorHandling' 'Error in ${MicroflowName}';
        RETURN $result;
    };

    /** === BUSINESS LOGIC HERE === */
    ${BusinessLogic}

    RETURN $result;
END;
```

