/** Define queries as reusable operations */
CREATE DATABASE QUERY Warehouse.GetInventoryLevels
    CONNECTION Warehouse.LegacyERP
    SQL 'SELECT product_code, quantity, warehouse_id
         FROM inventory
         WHERE quantity < $1'
    PARAMETER threshold: Integer
    RETURNS List of Warehouse.InventoryLevel
