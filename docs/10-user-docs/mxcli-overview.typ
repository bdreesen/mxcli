    [#strong[OQL Queries];], [Build complex data retrieval], [Optimized queries with joins],
    [#strong[Security];], [Configure access control], [Module roles, user roles, GRANT/REVOKE],
  )]
  , kind: table
  )

=== Skill Combinations
<skill-combinations>
#strong[Example 1: Complete Entity Module]

#emph[Request];: "Create a Product catalog with name, price, category, and inventory tracking"

#emph[AI combines];: Domain Model + Overview Page + Detail Page + Validation

```sql
/**
 * === DOMAIN MODEL ===
 * Generated by: Domain Model Skill
 */
CREATE MODULE ProductCatalog;

/** Product categories for catalog organization */
CREATE ENUMERATION ProductCatalog.ProductCategory (
    Electronics CAPTION 'Electronics',
    Clothing CAPTION 'Clothing',
    HomeGarden CAPTION 'Home & Garden',
    Sports CAPTION 'Sports & Outdoors',
    Books CAPTION 'Books & Media'
);

/**
 * Product catalog with inventory tracking.
 * Central product master data for e-commerce operations.
 */
@Position(100, 100)
CREATE PERSISTENT ENTITY ProductCatalog.Product (
    /** Product identification */
    SKU: String(50) NOT NULL UNIQUE,
    Name: String(200) NOT NULL,
    Description: String(2000),

    /** Pricing */
    Price: Decimal NOT NULL,
    CostPrice: Decimal,

    /** Categorization */
    Category: Enum ProductCatalog.ProductCategory NOT NULL,

    /** Inventory */
    StockQuantity: Integer DEFAULT 0,
    ReorderLevel: Integer DEFAULT 10,
    IsActive: Boolean DEFAULT true,

    /** Audit fields */
    CreatedAt: DateTime DEFAULT '[%CurrentDateTime%]',
    ModifiedAt: DateTime
);

CREATE INDEX idx_Product_Category
    ON ProductCatalog.Product (Category, IsActive);

/**
 * === VALIDATION MICROFLOWS ===
 * Generated by: Validation Skill
 */
CREATE MICROFLOW ProductCatalog.ValidateProduct($product: ProductCatalog.Product)
RETURNS Boolean AS $isValid
FOLDER 'Validation'
BEGIN
    DECLARE $isValid Boolean = true;

    /** SKU format validation */
    IF length($product/SKU) < 3 THEN
        VALIDATION FEEDBACK $product/SKU 'SKU must be at least 3 characters';
        SET $isValid = false;
    END IF;

    /** Price validation */
    IF $product/Price <= 0 THEN
        VALIDATION FEEDBACK $product/Price 'Price must be greater than zero';
        SET $isValid = false;
    END IF;

    /** Margin validation */
    IF $product/CostPrice != empty AND $product/CostPrice >= $product/Price THEN
        VALIDATION FEEDBACK $product/CostPrice 'Cost price should be less than selling price';
        SET $isValid = false;
    END IF;

    /** Inventory validation */
    IF $product/ReorderLevel < 0 THEN
        VALIDATION FEEDBACK $product/ReorderLevel 'Reorder level cannot be negative';
        SET $isValid = false;
    END IF;

    RETURN $isValid;
END;

/**
 * === OVERVIEW PAGE ===
 * Generated by: Overview Page Skill
 */
CREATE PAGE ProductCatalog.ProductOverview
(
  Title: 'Product Catalog',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'products'
)
{
