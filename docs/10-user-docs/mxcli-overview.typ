== MDL by Example
<mdl-by-example>
#strong[Note];: All examples use #strong[V3 syntax] - the current MDL syntax for pages and widgets. V3 uses: - Curly braces `{ }` for widget nesting (not `BEGIN/END`) - Property syntax with colons: `(Title: 'value', Layout: 'value')` - Explicit property names: `Label:`, `Binds:`, `DataSource:`, `Action:`

For complete V3 syntax reference, see the #link("./.ai-context/skills/")[skills documentation];.

=== Modules and Entities
<modules-and-entities>
The `@Position(x, y)` annotation controls where entities appear in the Studio Pro domain model diagram. Coordinates are in pixels from the top-left. This helps maintain clean, organized visual layouts when generating multiple entities.

```sql
/** Create a new module for sales functionality */
CREATE MODULE Sales;

/**
 * Order entity with business rules and audit support.
 * Sales orders with full audit trail.
 */
@Position(100, 100)
CREATE PERSISTENT ENTITY Sales.Order (
    /** Unique order identifier for external systems */
    OrderNumber: String(50) NOT NULL UNIQUE,

    /** Order timestamp, defaults to creation time */
    OrderDate: DateTime DEFAULT '[%CurrentDateTime%]',

    /** Monetary value with precision */
    TotalAmount: Decimal NOT NULL DEFAULT 0,

    /** Order lifecycle status */
    Status: Enum Sales.OrderStatus DEFAULT 'Draft',

    /** Soft delete support */
    IsArchived: Boolean DEFAULT false
);

/**
 * Order status enumeration for lifecycle tracking.
 * Lifecycle states for sales orders.
 */
CREATE ENUMERATION Sales.OrderStatus (
    Draft CAPTION 'Draft Order',
    Submitted CAPTION 'Submitted for Processing',
    Approved CAPTION 'Approved',
    Shipped CAPTION 'Shipped to Customer',
    Completed CAPTION 'Order Completed',
    Cancelled CAPTION 'Order Cancelled'
);

/**
 * Link orders to customers.
 * Each order belongs to exactly one customer.
 */
CREATE ASSOCIATION Sales.Order_Customer
    FROM Sales.Order
    TO Sales.Customer
    TYPE REFERENCE
    OWNER DEFAULT
    DELETE_BEHAVIOR DELETE_BUT_KEEP_REFERENCES;
```

=== Microflows (Business Logic)
<microflows-business-logic>
```sql
/**
 * Process a new order submission
 * Validates the order, updates inventory, and sends confirmation
 */
CREATE MICROFLOW Sales.SubmitOrder(
    $order: Sales.Order
) RETURNS Boolean AS $success
FOLDER 'Order Processing'
BEGIN
    DECLARE $success Boolean = false;

    /** Validate order has items */
    RETRIEVE $orderLines FROM Sales.OrderLine
        WHERE Sales.OrderLine_Order = $order;

    IF length($orderLines) = 0 THEN
        LOG WARNING NODE 'OrderValidation' 'Order has no items, cannot submit';
        RETURN false;
    END IF;

    /** Calculate total from line items */
    DECLARE $total Decimal = 0;
    LOOP $line IN $orderLines
    BEGIN
        SET $total = $total + $line/LineTotal;
    END LOOP;

    /** Update order status and commit */
    CHANGE $order (
        TotalAmount = $total,
        Status = 'Submitted',
        SubmittedAt = [%CurrentDateTime%]);
    COMMIT $order WITH EVENTS;

    /** Send confirmation email */
    CALL MICROFLOW Sales.SendOrderConfirmation(order = $order);

    SET $success = true;
    RETURN $success;
END;

/**
 * Retrieve orders for dashboard display
 * Returns recent orders with customer information
 */
CREATE MICROFLOW Sales.GetRecentOrders()
RETURNS List of Sales.Order AS $orders
BEGIN
    RETRIEVE $orders FROM (
        SELECT o.*
        FROM Sales.Order AS o
        WHERE o/IsArchived = false
        ORDER BY o/OrderDate DESC
        LIMIT 50
    );

    RETURN $orders;
END;
```

=== Pages (User Interface)
<pages-user-interface>
```sql
/**
 * Customer overview page with data grid
 * Allows viewing, filtering, and managing customers
 */
CREATE PAGE Sales.CustomerOverview
(
  Title: 'Customer Management',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'customer-overview'
)
{
  LAYOUTGRID mainGrid {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DYNAMICTEXT pageTitle (Content: 'Customer Overview', RenderMode: H3)
      }
    }
    ROW row2 {
      COLUMN col2 (DesktopWidth: 12) {
        DATAGRID CustomerGrid (
          DataSource: DATABASE FROM Sales.Customer SORT BY Name ASC
        ) {
          COLUMN colName (Attr: Name, Caption: 'Customer Name')
          COLUMN colEmail (Attr: Email, Caption: 'Email Address')
          COLUMN colPhone (Attr: Phone, Caption: 'Phone')
          COLUMN colActive (Attr: IsActive, Caption: 'Active')
          COLUMN colCreated (Attr: CreatedAt, Caption: 'Created')
        }
      }
    }
  }
}

/**
 * Customer edit form
 * Used for both new and existing customers
 */
CREATE PAGE Sales.Customer_NewEdit
(
  Params: { $Customer: Sales.Customer },
  Title: 'Customer Details',
  Layout: Atlas_Core.PopupLayout
)
{
  DATAVIEW dvCustomer (DataSource: $Customer) {
    TEXTBOX txtName (Label: 'Full Name', Binds: Name)
    TEXTBOX txtEmail (Label: 'Email Address', Binds: Email)
    TEXTBOX txtPhone (Label: 'Phone Number', Binds: Phone)
    CHECKBOX cbActive (Label: 'Active Customer', Binds: IsActive)

    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES)
    }
  }
}
```

