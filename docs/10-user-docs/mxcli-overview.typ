          }
          COLUMN colSku (Attr: SKU, Caption: 'SKU')
          COLUMN colName (Attr: Name, Caption: 'Product Name')
          COLUMN colCat (Attr: Category, Caption: 'Category')
          COLUMN colPrice (Attr: Price, Caption: 'Price')
          COLUMN colStock (Attr: StockQuantity, Caption: 'Stock')
          COLUMN colActive (Attr: IsActive, Caption: 'Active')
          COLUMN colActions (Caption: 'Actions') {
            ACTIONBUTTON btnEdit (
              Caption: 'Edit',
