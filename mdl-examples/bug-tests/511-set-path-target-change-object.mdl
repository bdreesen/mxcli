-- Bug #511: SET $obj/Module.Assoc = $other rejected with "variable not declared"
-- Root cause 1: isVariableDeclared did a direct map lookup on "$Order/Sales.Order_Customer"
--               instead of stripping $ and the path suffix first.
-- Root cause 2: path targets were dispatched to ChangeVariableAction (wrong BSON type);
--               they should produce a ChangeObjectAction.
-- Fix: in dispatchStatement, path targets route to addChangeObjectAction;
--      isVariableDeclared and extractVarName now strip $ prefix and path suffix.

-- Requires a project with Sales.Order and Sales.Customer entities and an
-- Order_Customer association.
create microflow Sales.ACT_LinkCustomer (
  $order: Sales.Order,
  $customer: Sales.Customer
)
begin
  set $order/Sales.Order_Customer = $customer;
  return;
end;
