/**
 * Example 5.1: Execute OQL statement
 *
 * Java Action Signature:
 *   JAVA ACTION OQLService.ExecuteOQL(
 *     OqlStatement: StringTemplate(Oql) NOT NULL
 *   ) RETURNS Long
 *
 * StringTemplate parameters allow structured query input.
 */
CREATE MICROFLOW JaTest.M040_ExecuteOQLUpdate ()
RETURNS Long AS $MF40_RowsAffected
BEGIN
  $MF40_RowsAffected = CALL JAVA ACTION JaTest.ExecuteOQL(
    OqlStatement = 'UPDATE JaTest.EmailMessage SET EmailStatus = ''Archived'' WHERE SentDate < [%BeginOfCurrentDay%]'
  );

  RETURN $MF40_RowsAffected;
END;
/

/**
 * Example 5.2: Execute SQL cleanup
 *
 * Java Action Signature:
 *   JAVA ACTION SQLService.ExecuteSQL(
 *     SqlStatement: StringTemplate(Sql) NOT NULL
 *   ) RETURNS Long
 */
CREATE MICROFLOW JaTest.M041_ExecuteSQLCleanup ($DaysOld: Integer)
RETURNS Long AS $MF41_DeletedCount
BEGIN
  -- Note: In real usage, parameterize properly to prevent SQL injection
  $MF41_DeletedCount = CALL JAVA ACTION JaTest.ExecuteSQL(
    SqlStatement = 'DELETE FROM log_entries WHERE log_timestamp < DATEADD(day, -30, GETDATE())'
  );

  RETURN $MF41_DeletedCount;
END;
/

/**
 * Example 5.3: OQL query returning results
 *
 * Java Action Signature:
 *   JAVA ACTION OQLService.ExecuteOQLQuery(
 *     OqlStatement: StringTemplate(Oql) NOT NULL
 *   ) RETURNS List of JaTest.LogEntry
 */
CREATE MICROFLOW JaTest.M042_QueryRecentErrors ()
RETURNS List OF JaTest.LogEntry AS $MF42_Errors
BEGIN
  $MF42_Errors = CALL JAVA ACTION JaTest.ExecuteOQLQuery(
    OqlStatement = 'SELECT * FROM JaTest.LogEntry WHERE LogLevel = ''ERROR'' ORDER BY LogTimestamp DESC'
  );

  RETURN $MF42_Errors;
END;
/

-- MARK: Level 6 - Complex Patterns

-- ============================================================================
-- LEVEL 6: Complex Java Action Patterns
-- ============================================================================

/**
 * Example 6.1: Chain multiple Java action calls
 *
 * Shows sequential Java action calls with data flowing between them.
 */
CREATE MICROFLOW JaTest.M050_ProcessAndNotify ($Email: JaTest.EmailMessage)
RETURNS Boolean AS $MF50_Success
BEGIN
  DECLARE $MF50_Success Boolean = false;

  -- Step 1: Validate email address
  $MF50_ValidationResult = CALL JAVA ACTION JaTest.ValidateEmail(
    EmailAddress = $Email/Recipient
  );

  IF $MF50_ValidationResult THEN
    -- Step 2: Send the email
    $MF50_SendResult = CALL JAVA ACTION JaTest.SendEmail(
      EmailMsg = $Email
    );

    -- Step 3: Log the result
    IF $MF50_SendResult THEN
      $MF50_InfoLog = CALL JAVA ACTION JaTest.CreateLogEntry(
        Level = 'INFO',
        Msg = 'Email sent successfully',
        LogSource ='M050_ProcessAndNotify'
      );
      SET $MF50_Success = true;
    ELSE
      $MF50_ErrorLog = CALL JAVA ACTION JaTest.CreateLogEntry(
        Level = 'ERROR',
        Msg = 'Failed to send email',
        LogSource ='M050_ProcessAndNotify'
      );
    END IF;
  ELSE
    $MF50_WarnLog = CALL JAVA ACTION JaTest.CreateLogEntry(
      Level = 'WARNING',
      Msg = 'Invalid email address',
      LogSource ='M050_ProcessAndNotify'
    );
  END IF;

  RETURN $MF50_Success;
END;
/

/**
 * Example 6.2: Java action in a loop
 *
 * Processing multiple items with individual Java action calls.
 */
CREATE MICROFLOW JaTest.M051_ProcessAllPending ()
RETURNS JaTest.ProcessResult AS $MF51_Result
BEGIN
  DECLARE $MF51_SuccessCount Integer = 0;
  DECLARE $MF51_FailCount Integer = 0;
  DECLARE $MF51_AllSuccess Boolean = false;

  -- Retrieve pending emails
  RETRIEVE $MF51_PendingEmails FROM JaTest.EmailMessage
    WHERE EmailStatus = 'Pending';

  -- Process each email
  LOOP $MF51_CurrentEmail IN $MF51_PendingEmails
  BEGIN
    $MF51_SendResult = CALL JAVA ACTION JaTest.SendEmail(
      EmailMsg = $MF51_CurrentEmail
    );

    IF $MF51_SendResult THEN
      CHANGE $MF51_CurrentEmail (EmailStatus = 'Sent', SentDate = [%CurrentDateTime%]);
      SET $MF51_SuccessCount = $MF51_SuccessCount + 1;
    ELSE
      CHANGE $MF51_CurrentEmail (EmailStatus = 'Failed');
      SET $MF51_FailCount = $MF51_FailCount + 1;
    END IF;
  END LOOP;

  -- Create result summary
  IF $MF51_FailCount = 0 THEN
    SET $MF51_AllSuccess = true;
  END IF;

  $MF51_Result = CREATE JaTest.ProcessResult (
    IsSuccess = $MF51_AllSuccess,
    ResultMessage = 'Processed emails',
    ProcessedCount = $MF51_SuccessCount,
    ErrorCount = $MF51_FailCount
  );

  RETURN $MF51_Result;
END;
/

/**
 * Example 6.3: Error handling with Java actions
 *
 * Demonstrates error handling patterns when calling Java actions.
 */
CREATE MICROFLOW JaTest.M052_SafeFileProcess ($FileDoc: JaTest.FileInfo)
RETURNS Boolean AS $MF52_Success
BEGIN
  DECLARE $MF52_Success Boolean = false;

  -- Attempt to process file with error handling
  -- Note: In practice, you'd use error handling settings on the activity

  $MF52_ProcessResult = CALL JAVA ACTION JaTest.ProcessFile(
    FileDoc = $FileDoc
  );

  IF $MF52_ProcessResult THEN
    $MF52_InfoLog = CALL JAVA ACTION JaTest.CreateLogEntry(
      Level = 'INFO',
      Msg = 'Successfully processed file',
      LogSource ='M052_SafeFileProcess'
    );
    SET $MF52_Success = true;
  ELSE
    $MF52_ErrorLog = CALL JAVA ACTION JaTest.CreateLogEntry(
      Level = 'ERROR',
      Msg = 'Failed to process file',
      LogSource ='M052_SafeFileProcess'
    );
  END IF;

  RETURN $MF52_Success;
END;
/

/**
 * Example 6.4: Conditional Java action calls
 *
 * Different Java actions based on runtime conditions.
 */
CREATE MICROFLOW JaTest.M053_ConditionalProcess (
  $Email: JaTest.EmailMessage,
  $Priority: String
)
RETURNS Boolean AS $MF53_Success
BEGIN
  DECLARE $MF53_Success Boolean = false;

  IF $Priority = 'HIGH' THEN
    -- Use priority sending service
    $UrgentResult = CALL JAVA ACTION JaTest.SendUrgent(
      EmailMsg = $Email
    );
    SET $MF53_Success = $UrgentResult;
  ELSIF $Priority = 'BULK' THEN
    -- Use bulk sending service
    $QueueResult = CALL JAVA ACTION JaTest.QueueForSending(
      EmailMsg = $Email
    );
    SET $MF53_Success = $QueueResult;
  ELSE
    -- Standard sending
    $StandardResult = CALL JAVA ACTION JaTest.SendEmail(
      EmailMsg = $Email
    );
    SET $MF53_Success = $StandardResult;
  END IF;

  RETURN $MF53_Success;
END;
/

-- MARK: Level 7 - Advanced Patterns

-- ============================================================================
-- LEVEL 7: Advanced Integration Patterns
-- ============================================================================

/**
 * Example 7.1: REST API call via Java action
 *
 * Java Action Signature:
 *   JAVA ACTION RestClient.CallAPI(
 *     ApiUrl: String NOT NULL,
 *     HttpMethod: String NOT NULL,
 *     HttpHeaders: String,
 *     RequestBody: String
 *   ) RETURNS String
 */
CREATE MICROFLOW JaTest.M060_CallExternalAPI ($Endpoint: String)
RETURNS String AS $MF60_Response
BEGIN
  DECLARE $MF60_ApiUrl String = 'https://jsonplaceholder.typicode.com/' + $Endpoint;

  $MF60_Response = CALL JAVA ACTION JaTest.CallAPI(
    ApiUrl = $MF60_ApiUrl,
    HttpMethod = 'GET',
    HttpHeaders = 'Authorization: Bearer token123',
    RequestBody = empty
  );
  LOG INFO NODE 'Test' 'CallApi complete: {1} -> {2} -> {3}' WITH ({1} = $Endpoint, {2} = $MF60_ApiUrl, {3} = $MF60_Response);  
  RETURN $MF60_Response;
END;
/

/**
 * Example 7.2: Cryptographic operations
 *
 * Java Action Signature:
 *   JAVA ACTION CryptoService.HashText(
 *     PlainText: String NOT NULL,
 *     SaltValue: String
 *   ) RETURNS String
 */
CREATE MICROFLOW JaTest.M061_HashPassword ($PlainText: String)
RETURNS String AS $MF61_HashedText
BEGIN
  -- Generate salt
  $MF61_SaltValue = CALL JAVA ACTION JaTest.GenerateSalt();

  -- Hash with salt
  $MF61_HashedText = CALL JAVA ACTION JaTest.HashText(
    PlainText = $PlainText,
    SaltValue = $MF61_SaltValue
  );

  RETURN $MF61_HashedText;
END;
/

/**
 * Example 7.3: File operations
 *
 * Java Action Signature:
 *   JAVA ACTION FileService.ReadFileContents(
 *     FileDoc: JaTest.FileInfo NOT NULL,
 *     Encoding: String
 *   ) RETURNS String
 */
CREATE MICROFLOW JaTest.M062_ReadFileAsText ($FileDoc: JaTest.FileInfo)
RETURNS String AS $MF62_Contents
BEGIN
  $MF62_Contents = CALL JAVA ACTION JaTest.ReadFileContents(
    FileDoc = $FileDoc,
    Encoding = 'UTF-8'
  );

  RETURN $MF62_Contents;
END;
/

/**
 * Example 7.4: Async/background processing trigger
 *
 * Java Action Signature:
 *   JAVA ACTION AsyncService.QueueTask(
 *     TaskType: String NOT NULL,
 *     TaskParams: String NOT NULL,
 *     TaskPriority: Integer
 *   ) RETURNS String
 *
 * Returns a task ID for tracking.
 */
CREATE MICROFLOW JaTest.M063_QueueBackgroundTask (
  $TaskType: String,
  $TaskParams: String
)
RETURNS String AS $MF63_TaskId
BEGIN
  $MF63_TaskId = CALL JAVA ACTION JaTest.QueueTask(
    TaskType = $TaskType,
    TaskParams = $TaskParams,
    TaskPriority = 5
  );

  RETURN $MF63_TaskId;
END;
/

