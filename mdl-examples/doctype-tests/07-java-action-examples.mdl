/**
 * Example 4.1: List of entities as input
 *
 * Java Action Signature:
 *   JAVA ACTION BatchProcessor.ProcessEmails(
 *     Emails: List of JaTest.EmailMessage NOT NULL
 *   ) RETURNS JaTest.ProcessResult
 */
CREATE MICROFLOW JaTest.M030_BatchSendEmails ()
RETURNS JaTest.ProcessResult AS $MF30_Result
BEGIN
  -- Retrieve pending emails
  RETRIEVE $MF30_PendingEmails FROM JaTest.EmailMessage
    WHERE EmailStatus = 'Pending';

  -- Process batch via Java action
  $MF30_Result = CALL JAVA ACTION JaTest.ProcessEmails(
    Emails = $MF30_PendingEmails
  );

  RETURN $MF30_Result;
END;
/

/**
 * Example 4.2: List as return type
 *
 * Java Action Signature:
 *   JAVA ACTION SearchService.FindByKeyword(
 *     Keyword: String NOT NULL,
 *     MaxResults: Integer
 *   ) RETURNS List of JaTest.LogEntry
 */
CREATE MICROFLOW JaTest.M031_SearchLogs ($Keyword: String)
RETURNS List OF JaTest.LogEntry AS $MF31_Results
BEGIN
  $MF31_Results = CALL JAVA ACTION JaTest.FindByKeyword(
    Keyword = $Keyword,
    MaxResults = 100
  );

  RETURN $MF31_Results;
END;
/

/**
 * Example 4.3: Filter list using Java action
 *
 * Java Action Signature:
 *   JAVA ACTION FilterService.FilterByPriority(
 *     Entries: List of JaTest.LogEntry NOT NULL,
 *     MinLevel: String NOT NULL
 *   ) RETURNS List of JaTest.LogEntry
 */
CREATE MICROFLOW JaTest.M032_FilterErrorLogs ()
RETURNS List OF JaTest.LogEntry AS $MF32_ErrorLogs
BEGIN
  -- Get all logs
  RETRIEVE $MF32_AllLogs FROM JaTest.LogEntry;

  -- Filter to errors using Java action
  $MF32_ErrorLogs = CALL JAVA ACTION JaTest.FilterByPriority(
    Entries = $MF32_AllLogs,
    MinLevel = 'ERROR'
  );

  RETURN $MF32_ErrorLogs;
END;
/

