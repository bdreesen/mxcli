-- ----------------------------------------------------------------------------
-- Level 7: Advanced Integration Java Actions
-- ----------------------------------------------------------------------------

/**
 * Makes an HTTP REST API call.
 * Stub: Returns simulated JSON response.
 */
CREATE JAVA ACTION JaTest.CallAPI(ApiUrl: String NOT NULL, HttpMethod: String NOT NULL, HttpHeaders: String, RequestBody: String) RETURNS String
AS $$
if (ApiUrl == null || ApiUrl.isEmpty()) {
    return "{\"error\":\"ApiUrl is required\"}";
}
if (HttpMethod == null || HttpMethod.isEmpty()) {
    return "{\"error\":\"HttpMethod is required\"}";
}

java.net.URL url = new java.net.URL(ApiUrl);
java.net.HttpURLConnection conn = (java.net.HttpURLConnection) url.openConnection();
try {
    conn.setRequestMethod(HttpMethod.toUpperCase());
    conn.setConnectTimeout(30000);
    conn.setReadTimeout(30000);

    // Set headers
    if (HttpHeaders != null && !HttpHeaders.isEmpty()) {
        for (String header : HttpHeaders.split("\n")) {
            header = header.trim();
            int sep = header.indexOf(':');
            if (sep > 0) {
                String key = header.substring(0, sep).trim();
                String value = header.substring(sep + 1).trim();
                conn.setRequestProperty(key, value);
            }
        }
    }

    // Send request body for POST/PUT/PATCH
    if (RequestBody != null && !RequestBody.isEmpty()
            && ("POST".equalsIgnoreCase(HttpMethod)
                || "PUT".equalsIgnoreCase(HttpMethod)
                || "PATCH".equalsIgnoreCase(HttpMethod))) {
        conn.setDoOutput(true);
        if (conn.getRequestProperty("Content-Type") == null) {
            conn.setRequestProperty("Content-Type", "application/json");
        }
        try (java.io.OutputStream os = conn.getOutputStream()) {
            os.write(RequestBody.getBytes(java.nio.charset.StandardCharsets.UTF_8));
        }
    }

    int status = conn.getResponseCode();
    java.io.InputStream is = (status >= 200 && status < 400)
        ? conn.getInputStream()
        : conn.getErrorStream();

    String body = "";
    if (is != null) {
        try (java.io.BufferedReader reader = new java.io.BufferedReader(
                new java.io.InputStreamReader(is, java.nio.charset.StandardCharsets.UTF_8))) {
            StringBuilder sb = new StringBuilder();
            String line;
            while ((line = reader.readLine()) != null) {
                sb.append(line);
            }
            body = sb.toString();
        }
    }

    return body;
} finally {
    conn.disconnect();
}
$$;

/**
 * Generates a random salt for password hashing.
 */
CREATE JAVA ACTION JaTest.GenerateSalt() RETURNS String
AS $$
java.security.SecureRandom random = new java.security.SecureRandom();
byte[] salt = new byte[16];
random.nextBytes(salt);
StringBuilder sb = new StringBuilder();
for (byte b : salt) {
    sb.append(String.format("%02x", b));
}
return sb.toString();
$$;

/**
 * Hashes text with an optional salt using SHA-256.
 */
CREATE JAVA ACTION JaTest.HashText(PlainText: String NOT NULL, SaltValue: String) RETURNS String
AS $$
if (PlainText == null) {
    return "";
}
try {
    String toHash = PlainText + (SaltValue != null ? SaltValue : "");
    java.security.MessageDigest digest = java.security.MessageDigest.getInstance("SHA-256");
    byte[] hash = digest.digest(toHash.getBytes(java.nio.charset.StandardCharsets.UTF_8));
    StringBuilder sb = new StringBuilder();
    for (byte b : hash) {
        sb.append(String.format("%02x", b));
    }
    return sb.toString();
} catch (java.security.NoSuchAlgorithmException e) {
    return "";
}
$$;

