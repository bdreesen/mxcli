-- MARK: Level 8 - Type Parameters & Toolbox Exposure

-- ============================================================================
-- LEVEL 8: Type Parameters (Generics) & EXPOSED AS (Toolbox Exposure)
-- ============================================================================
-- Type parameters let Java actions accept entity types dynamically via generics.
-- EXPOSED AS makes the action appear as a toolbox item in Studio Pro.

-- ----------------------------------------------------------------------------
-- 8.1: Single Type Parameter — Generic entity processor
-- ----------------------------------------------------------------------------
-- ENTITY <pEntity> declares a type parameter inline. The parameter typed as
-- ENTITY <pEntity> becomes the entity type selector (receives entity type name).
-- Subsequent bare pEntity parameters receive entity instances.

CREATE JAVA ACTION JaTest.GenericEntityValidator(
  EntityType: ENTITY <pEntity> NOT NULL,
  InputObject: pEntity NOT NULL
) RETURNS Boolean
AS $$
// Generic validation - works with any entity type
if (InputObject == null) return false;
return InputObject.getMembers().values().stream()
    .allMatch(m -> !m.isRequired() || m.getValue(getContext()) != null);
$$;
/

-- ----------------------------------------------------------------------------
-- 8.2: Type Parameter with Multiple Parameters
-- ----------------------------------------------------------------------------
-- ENTITY <pEntity> declares the type parameter. The ENTITY <pEntity> parameter
-- becomes the entity type selector (EntityTypeParameterType) and receives the
-- entity type name (e.g., 'Module.Entity'). Bare pEntity parameters become
-- ParameterizedEntityType and receive entity instances (e.g., $Variable).

CREATE JAVA ACTION JaTest.CopyAttributes(
  EntityType: ENTITY <pEntity> NOT NULL,
  Source: pEntity NOT NULL,
  Target: pEntity NOT NULL,
  AttributeNames: String NOT NULL
) RETURNS Boolean
AS $$
// Copy specified attributes from source to target entity
String[] attrs = AttributeNames.split(",");
for (String attr : attrs) {
    String trimmed = attr.trim();
    Target.setValue(getContext(), trimmed,
        Source.getValue(getContext(), trimmed));
}
return true;
$$;
/

-- ----------------------------------------------------------------------------
-- 8.3: EXPOSED AS — Toolbox-visible action (no type params)
-- ----------------------------------------------------------------------------
-- EXPOSED AS makes the action appear in Studio Pro's microflow toolbox.

CREATE JAVA ACTION JaTest.FormatCurrency(
  Amount: Decimal NOT NULL,
  CurrencyCode: String NOT NULL
) RETURNS String
EXPOSED AS 'Format Currency' IN 'Formatting'
AS $$
java.text.NumberFormat formatter = java.text.NumberFormat.getCurrencyInstance();
formatter.setCurrency(java.util.Currency.getInstance(CurrencyCode));
return formatter.format(Amount);
$$;
/

-- ----------------------------------------------------------------------------
-- 8.4: Type Parameter + EXPOSED AS combined
-- ----------------------------------------------------------------------------
-- A generic action exposed in the toolbox.

CREATE JAVA ACTION JaTest.DeepClone(
  EntityType: ENTITY <pEntity> NOT NULL,
  Original: pEntity NOT NULL
) RETURNS Boolean
EXPOSED AS 'Deep Clone Object' IN 'Object Utils'
AS $$
// Deep clone an entity including associated objects
com.mendix.core.Core.instantiate(getContext(),
    Original.getType()).setValues(getContext(),
    Original.getMembers());
return true;
$$;
/

-- ----------------------------------------------------------------------------
-- 8.5: Microflow calling a type-parameter Java action
-- ----------------------------------------------------------------------------
-- When calling a generic Java action, the EntityType param receives the entity
-- type name as a string literal (EntityTypeCodeActionParameterValue), while
-- instance params receive variables (BasicCodeActionParameterValue).

CREATE MICROFLOW JaTest.Test_M070 ()
RETURNS Boolean AS $IsValid
BEGIN
  $Email = CREATE JaTest.EmailMessage (Recipient = 'test@example.com');
  $IsValid = CALL JAVA ACTION JaTest.GenericEntityValidator(
    EntityType = 'JaTest.EmailMessage',
    InputObject = $Email
  );

  RETURN $IsValid;
END;
/

-- ----------------------------------------------------------------------------
-- 8.6: Microflow calling type-parameter action with multiple params
-- ----------------------------------------------------------------------------
-- The EntityType param gets the entity type name as a string literal,
-- while Source/Target params get entity instances as variable references.

CREATE MICROFLOW JaTest.Test_M071 ()
RETURNS Boolean AS $Result
BEGIN
  $Source = CREATE JaTest.ProcessResult (IsSuccess = true, ResultMessage = 'Source', ProcessedCount = 10);
  $Target = CREATE JaTest.ProcessResult (IsSuccess = false, ResultMessage = 'Target', ProcessedCount = 0);

  $Result = CALL JAVA ACTION JaTest.CopyAttributes(
    EntityType = 'JaTest.ProcessResult',
    Source = $Source,
    Target = $Target,
    AttributeNames = 'ProcessedCount,ResultMessage'
  );

  RETURN $Result;
END;
/

-- ----------------------------------------------------------------------------
-- 8.7: Microflow calling EXPOSED action
-- ----------------------------------------------------------------------------

CREATE MICROFLOW JaTest.Test_M072 ()
RETURNS String AS $Formatted
BEGIN
  $Formatted = CALL JAVA ACTION JaTest.FormatCurrency(
    Amount = 1234.56,
    CurrencyCode = 'USD'
  );

  RETURN $Formatted;
END;
/

-- MARK: Summary

-- ============================================================================
-- Java Action Feature Summary
-- ============================================================================
--
-- DESCRIBE JAVA ACTION shows action signature:
--   JAVA ACTION Module.Name(params) RETURNS type
--   ... with ENTITY <pEntity> for type parameter declarations
--   ... EXPOSED AS 'Caption' IN 'Category'
--
-- Call syntax in microflows:
--   $Result = CALL JAVA ACTION Module.Name(
--     ParamName = value,
--     AnotherParam = $variable
--   );
--
-- Parameter Types Supported:
--   - String, Integer, Long, Decimal, Boolean, DateTime
--   - Entity types (Module.EntityName)
--   - List of Entity (List of Module.EntityName)
--   - StringTemplate(Oql), StringTemplate(Sql) for queries
--   - Microflow (for callback patterns)
--   - Enumeration types
--   - Type parameters (ENTITY <pEntity> declares, bare pEntity references)
--
-- Return Types Supported:
--   - Void (no return, no assignment needed)
--   - String, Integer, Long, Decimal, Boolean, DateTime
--   - Entity types
--   - List of Entity
--
-- Key Patterns:
--   1. Utility functions (no params, primitive return)
--   2. Data transformation (primitive params, primitive return)
--   3. Entity processing (entity param, Boolean/entity return)
--   4. Batch processing (list param, result entity return)
--   5. Database operations (OQL/SQL template params)
--   6. External integrations (string params for URLs/APIs)
--   7. Chained calls (output of one is input to next)
--   8. Generic actions with type parameters (ENTITY <pEntity>)
--   9. Toolbox-exposed actions (EXPOSED AS 'caption' IN 'category')
--
-- ============================================================================
