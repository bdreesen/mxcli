-- ============================================================================
-- Math.IsPrime Tests
-- ============================================================================

/**
 * Unit test for Math.IsPrime
 *
 * Test: Verifies that 17 is correctly identified as prime
 *
 * ARRANGE: Set up test input (17 is a known prime)
 * ACT: Call Math.IsPrime(17)
 * ASSERT: Verify result is true
 */
CREATE MICROFLOW Math.UT_IsPrime_17_ReturnsTrue ()
RETURNS String AS $TestResult
FOLDER 'Tests/Math'
URL 'UT_IsPrime_17_ReturnsTrue'
BEGIN
  DECLARE $TestResult String = empty;
  DECLARE $Input Integer = 17;
  DECLARE $Expected Boolean = true;

  $Actual = CALL MICROFLOW Math.IsPrime($Number = $Input);

  IF $Actual = $Expected THEN
    SET $TestResult = 'PASS: IsPrime(17) returned true as expected';
  ELSE
    SET $TestResult = 'FAIL: IsPrime(17) returned ' + toString($Actual) + ', expected true';
  END IF;
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$TestResult];

  RETURN $TestResult;
END;
/

/**
 * Unit test for Math.IsPrime
 *
 * Test: Verifies that 20 is correctly identified as not prime
 *
 * ARRANGE: Set up test input (20 = 4 * 5, not prime)
 * ACT: Call Math.IsPrime(20)
 * ASSERT: Verify result is false
 */
CREATE MICROFLOW Math.UT_IsPrime_20_ReturnsFalse ()
RETURNS String AS $TestResult
FOLDER 'Tests/Math'
URL 'UT_IsPrime_20_ReturnsFalse'
BEGIN
  DECLARE $TestResult String = empty;
  DECLARE $Input Integer = 20;
  DECLARE $Expected Boolean = false;

  $Actual = CALL MICROFLOW Math.IsPrime($Number = $Input);

  IF $Actual = $Expected THEN
    SET $TestResult = 'PASS: IsPrime(20) returned false as expected';
  ELSE
    SET $TestResult = 'FAIL: IsPrime(20) returned ' + toString($Actual) + ', expected false';
  END IF;
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$TestResult];

  RETURN $TestResult;
END;
/

/**
 * Unit test for Math.IsPrime
 *
 * Test: Verifies that 2 is correctly identified as prime (edge case)
 *
 * ARRANGE: Set up test input (2 is the only even prime)
 * ACT: Call Math.IsPrime(2)
 * ASSERT: Verify result is true
 */
CREATE MICROFLOW Math.UT_IsPrime_2_ReturnsTrue ()
RETURNS String AS $TestResult
FOLDER 'Tests/Math'
