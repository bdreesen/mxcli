/**
 * Unit test for Math.IsPrime
 *
 * Test: Verifies that negative numbers are correctly identified as not prime
 *
 * ARRANGE: Set up test input (-5 is not prime)
 * ACT: Call Math.IsPrime(-5)
 * ASSERT: Verify result is false
 */
CREATE MICROFLOW Math.UT_IsPrime_Negative_ReturnsFalse ()
RETURNS String AS $TestResult
FOLDER 'Tests/Math'
URL 'UT_IsPrime_Negative_ReturnsFalse'
BEGIN
  DECLARE $TestResult String = empty;
  DECLARE $Input Integer = -5;
  DECLARE $Expected Boolean = false;

  $Actual = CALL MICROFLOW Math.IsPrime($Number = $Input);

  IF $Actual = $Expected THEN
    SET $TestResult = 'PASS: IsPrime(-5) returned false as expected';
  ELSE
    SET $TestResult = 'FAIL: IsPrime(-5) returned ' + toString($Actual) + ', expected false';
  END IF;
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$TestResult];

  RETURN $TestResult;
END;
/

/**
 * Test Suite: All tests for Math.IsPrime
 *
 * This microflow runs all unit tests for IsPrime and returns
 * a summary of results.
 */
CREATE MICROFLOW Math.TestSuite_IsPrime ()
RETURNS String AS $Summary
FOLDER 'Tests/Math'
URL 'TestSuite_IsPrime'
BEGIN
  DECLARE $TestsPassed Integer = 0;
  DECLARE $TotalTests Integer = 6;
  DECLARE $Summary String = '';

  -- Run all IsPrime tests
  $Result1 = CALL MICROFLOW Math.UT_IsPrime_17_ReturnsTrue();
  IF $Result1 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result2 = CALL MICROFLOW Math.UT_IsPrime_20_ReturnsFalse();
  IF $Result2 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result3 = CALL MICROFLOW Math.UT_IsPrime_2_ReturnsTrue();
  IF $Result3 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result4 = CALL MICROFLOW Math.UT_IsPrime_1_ReturnsFalse();
  IF $Result4 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result5 = CALL MICROFLOW Math.UT_IsPrime_0_ReturnsFalse();
  IF $Result5 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result6 = CALL MICROFLOW Math.UT_IsPrime_Negative_ReturnsFalse();
  IF $Result6 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  SET $Summary = 'Test Suite: IsPrime - Passed: ' + toString($TestsPassed) + ' / Total: ' + toString($TotalTests);
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$Summary];

  RETURN $Summary;
END;
/

