  $Actual = CALL MICROFLOW Math.IsPrime($Number = $Input);

  IF $Actual = $Expected THEN
    SET $TestResult = 'PASS: IsPrime(2) returned true as expected';
  ELSE
    SET $TestResult = 'FAIL: IsPrime(2) returned ' + toString($Actual) + ', expected true';
  END IF;
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$TestResult];

  RETURN $TestResult;
END;
/

