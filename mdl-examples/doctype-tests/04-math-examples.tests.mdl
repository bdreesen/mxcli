/**
 * Test Suite: All tests for Math.Fibonacci
 *
 * This microflow runs all unit tests for Fibonacci and returns
 * a summary of results.
 */
CREATE MICROFLOW Math.TestSuite_Fibonacci ()
RETURNS String AS $Summary
FOLDER 'Tests/Math'
URL 'TestSuite_Fibonacci'
BEGIN
  DECLARE $TestsPassed Integer = 0;
  DECLARE $TotalTests Integer = 5;
  DECLARE $Summary String = '';

  -- Run all Fibonacci tests
  $Result1 = CALL MICROFLOW Math.UT_Fibonacci_0_Returns0();
  IF $Result1 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result2 = CALL MICROFLOW Math.UT_Fibonacci_1_Returns1();
  IF $Result2 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result3 = CALL MICROFLOW Math.UT_Fibonacci_10_Returns55();
  IF $Result3 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result4 = CALL MICROFLOW Math.UT_Fibonacci_20_Returns6765();
  IF $Result4 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result5 = CALL MICROFLOW Math.UT_Fibonacci_Negative_Returns0();
  IF $Result5 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  SET $Summary = 'Test Suite: Fibonacci - Passed: ' + toString($TestsPassed) + ' / Total: ' + toString($TotalTests);
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$Summary];

  RETURN $Summary;
END;
/

-- ============================================================================
-- Master Test Suite
-- ============================================================================

/**
 * Master Test Suite: All Math tests
 *
 * Runs all test suites and returns overall summary.
 */
CREATE MICROFLOW Math.TestSuite_All ()
RETURNS String AS $Summary
FOLDER 'Tests/Math'
URL 'TestSuite_All'
BEGIN
  DECLARE $Summary String = '';

  -- Run all test suites
  $IsPrimeResult = CALL MICROFLOW Math.TestSuite_IsPrime();
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$IsPrimeResult];

  $FibonacciResult = CALL MICROFLOW Math.TestSuite_Fibonacci();
  LOG INFO NODE 'TestSuite' '{1}' OBJECTS[$FibonacciResult];

  SET $Summary = 'All Math Tests Complete. ' + $IsPrimeResult + ' | ' + $FibonacciResult;

  RETURN $Summary;
END;
/

-- ============================================================================
-- Updated Test Runner Page
-- ============================================================================

/**
 * Math Test Runner Page
 *
 * A dashboard to run all Math test microflows and view results.
 */
CREATE PAGE Math.MathTestRunner
TITLE 'Math Test Runner'
LAYOUT 'Atlas_Core.Atlas_Default'
URL 'mathtestrunner'
FOLDER 'Tests/Math'
BEGIN
  LAYOUTGRID gridMain
    ROW
      COLUMN (DESKTOP_WIDTH 12)
        DYNAMICTEXT titleHeader ( CONTENT 'Math Microflow Test Runner', RENDERMODE 'H2');
        DYNAMICTEXT textDescription ( CONTENT 'Run unit tests for Math.IsPrime and Math.Fibonacci microflows', RENDERMODE 'Paragraph');
    ROW
      COLUMN (DESKTOP_WIDTH 12)
        DYNAMICTEXT sectionAll ( CONTENT 'Run All Tests', RENDERMODE 'H4');
    ROW
      COLUMN (DESKTOP_WIDTH 4)
        ACTIONBUTTON btnRunAll 'Run All Math Tests'
          ACTION CALL_MICROFLOW 'Math.TestSuite_All' STYLE Primary;
    ROW
      COLUMN (DESKTOP_WIDTH 12)
        DYNAMICTEXT sectionIsPrime ( CONTENT 'IsPrime Tests', RENDERMODE 'H4');
    ROW
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnIsPrimeSuite 'Run IsPrime Suite'
          ACTION CALL_MICROFLOW 'Math.TestSuite_IsPrime' STYLE Primary;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnIsPrime17 'Test: 17 is prime'
          ACTION CALL_MICROFLOW 'Math.UT_IsPrime_17_ReturnsTrue' STYLE Default;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnIsPrime20 'Test: 20 not prime'
          ACTION CALL_MICROFLOW 'Math.UT_IsPrime_20_ReturnsFalse' STYLE Default;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnIsPrime2 'Test: 2 is prime'
          ACTION CALL_MICROFLOW 'Math.UT_IsPrime_2_ReturnsTrue' STYLE Default;
    ROW
      COLUMN (DESKTOP_WIDTH 12)
        DYNAMICTEXT sectionFibonacci ( CONTENT 'Fibonacci Tests', RENDERMODE 'H4');
    ROW
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnFibSuite 'Run Fibonacci Suite'
          ACTION CALL_MICROFLOW 'Math.TestSuite_Fibonacci' STYLE Primary;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnFib0 'Test: F(0) = 0'
          ACTION CALL_MICROFLOW 'Math.UT_Fibonacci_0_Returns0' STYLE Default;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnFib10 'Test: F(10) = 55'
          ACTION CALL_MICROFLOW 'Math.UT_Fibonacci_10_Returns55' STYLE Default;
      COLUMN (DESKTOP_WIDTH 3)
        ACTIONBUTTON btnFib20 'Test: F(20) = 6765'
          ACTION CALL_MICROFLOW 'Math.UT_Fibonacci_20_Returns6765' STYLE Default;
END;
/
